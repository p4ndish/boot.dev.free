# Boot.dev Clone — Configuration
# Copy to .env and modify for your environment

# Database (defaults avoid conflicts with existing postgres)
DB_HOST=localhost
DB_PORT=5433
DB_NAME=bootdev_clone
DB_USER=bootdev
DB_PASS=bootdev

# Go API Server
API_PORT=8080

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8080

# Docker (only used in docker-compose — skippable)
DOCKER_COMPOSE_PROJECT_NAME=bootdev-clone
COMPOSE_FILE=docker-compose.yml
